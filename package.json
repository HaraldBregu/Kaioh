{
  "name": "ai-assistant",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node --enable-source-maps dist/main.js",
    "gateway": "node --enable-source-maps dist/gateway.js",
    "dev": "tsx src/main.ts",
    "dev:gateway": "tsx src/gateway.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "cron-parser": "^4.9.0",
    "grammy": "^1.30.0",
    "marked": "^14.1.3",
    "marked-terminal": "^7.2.1",
    "openai": "^4.68.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  }
}
